# -----------------------------------------------------------------------
# Frontend (Vite) — exposed to the browser, safe because access is
# governed by Row Level Security, not by secrecy of these values.
# -----------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# -----------------------------------------------------------------------
# Seed script only (supabase/seed/seed.mjs) — NEVER prefix with VITE_,
# NEVER commit, NEVER ship to the browser. Found in
# Supabase Dashboard → Project Settings → API → service_role key.
# -----------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
